# =========================
# nuwax_robot_bridge 主配置文件
# 说明：
# 1. 这里是用户直接编辑的配置入口。
# 2. 格式统一为 KEY=VALUE。
# 3. 以 # 开头的是注释。
# 4. 同名环境变量会覆盖这里的值。
# =========================

# 日志配置
GO2_PROXY_LOG_DIR=/home/unitree/nuwax_robot_bridge
GO2_PROXY_LOG_FILE=/home/unitree/nuwax_robot_bridge/go2_proxy.log
GO2_PROXY_LOG_LEVEL=INFO
GO2_PROXY_LOG_MAX_LINES=100000
GO2_PROXY_LOG_TRIM_CHECK_INTERVAL=200

# TCP 服务配置
GO2_PROXY_TCP_HOST=0.0.0.0
GO2_PROXY_TCP_PORT=8765

# DDS 与 SDK 配置
GO2_DDS_IFACE=eth0
GO2_SDK_PATH=/home/unitree/unitree_sdk2_python
CYCLONEDDS_URI=<CycloneDDS><Domain><Compatibility><StandardsConformance>lax</StandardsConformance></Compatibility></Domain></CycloneDDS>

# 低级控制默认参数
GO2_LOW_LEVEL_KP=60.0
GO2_LOW_LEVEL_KD=5.0
GO2_LOW_LEVEL_MAX_VELOCITY=2.0
GO2_LOW_LEVEL_MAX_TORQUE=10.0
GO2_LOW_LEVEL_INTERVAL_SEC=0.002

# 豆包双向流式鉴权配置
DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
DOUBAO_RESOURCE_ID=seed-tts-1.0
DOUBAO_DEFAULT_SPEAKER=zh_female_sajiaonvyou_moon_bigtts
DOUBAO_DEFAULT_UID=nuwax_robot_bridge-tts
DOUBAO_DEFAULT_MODEL=
DOUBAO_DEFAULT_AUDIO_FORMAT=pcm
DOUBAO_DEFAULT_SAMPLE_RATE=24000
DOUBAO_REQUEST_USAGE_TOKENS=true
DOUBAO_SEND_APP_ID_HEADER=false
DOUBAO_SEND_APP_KEY_HEADER=true

# TTS 播放器运行配置
TTS_PLAYER_AUTO_START=true
TTS_PLAYER_PRINT_SUBTITLE=false
TTS_PLAYER_VOLUME=1.0

# 播放后端配置
# 可选：
# - robot_webrtc  : Go2 机身扬声器新链路（默认）
# - alsa_local    : Jetson 本地 ALSA/Pulse 兼容链路
TTS_PLAYER_BACKEND_MODE=robot_webrtc
TTS_PLAYER_FALLBACK_BACKEND_MODE=alsa_local

# Jetson 本地 ALSA/Pulse 兼容链路配置
TTS_PLAYER_PREFERRED_BACKEND=aplay
TTS_PLAYER_AUDIO_DEVICE=
TTS_PLAYER_ENABLE_SPK_CTL=true
TTS_PLAYER_ENABLE_APE_ROUTE=true
TTS_PLAYER_APE_CARD=APE
TTS_PLAYER_APE_ADMAIF=1
TTS_PLAYER_APE_SPEAKER=DSPK1

# Go2 机身扬声器新链路配置
# 这里需要填写机器人 WebRTC 可访问地址
TTS_PLAYER_ROBOT_IP=
TTS_PLAYER_ROBOT_MODE=ai
# 如果 unitree_webrtc_connect 安装在非系统默认 site-packages，可在这里补充路径。
# 支持多路径，Linux 下使用 : 分隔。
TTS_PLAYER_ROBOT_PYTHONPATH=
TTS_PLAYER_USE_MEGAPHONE=true
# 实时 megaphone 目前仍是实验路径，默认关闭，优先走稳定的整段上传播放。
TTS_PLAYER_STREAMING_ENABLED=false
TTS_PLAYER_STREAMING_CHUNK_MS=200
TTS_PLAYER_ROBOT_CONNECT_TIMEOUT=15.0
TTS_PLAYER_ROBOT_REQUEST_TIMEOUT=20.0
TTS_PLAYER_UPLOAD_CHUNK_SIZE=61440
TTS_PLAYER_MEGAPHONE_CHUNK_SIZE=16384
TTS_PLAYER_SEGMENT_MIN_DURATION_SEC=3.0
TTS_PLAYER_AUTO_FALLBACK_TO_LOCAL=true

# 日志监听转 TTS 配置
# 说明：
# 1. 直接监听 nuwaxbot 主日志里的 agent_message_chunk。
# 2. 在宿主机内直接调用本地 Doubao 双向流式客户端。
# 3. 由于 /var/lib/docker/volumes/... 通常只有 root 可读，建议整个代理进程以 root 启动。
TTS_LOG_BRIDGE_ENABLED=false
TTS_LOG_BRIDGE_LOG_PATH=/var/lib/docker/volumes/nuwax_home/_data/.nuwaxbot/logs/main.log
TTS_LOG_BRIDGE_REQUIRE_ROOT=true
TTS_LOG_BRIDGE_SPEAKER=
TTS_LOG_BRIDGE_RESOURCE_ID=seed-tts-1.0
TTS_LOG_BRIDGE_UID=nuwax_robot_bridge-tts
TTS_LOG_BRIDGE_MODEL=
TTS_LOG_BRIDGE_AUDIO_FORMAT=pcm
TTS_LOG_BRIDGE_SAMPLE_RATE=24000
TTS_LOG_BRIDGE_SPEECH_RATE=0
TTS_LOG_BRIDGE_LOUDNESS_RATE=0
TTS_LOG_BRIDGE_EMOTION=
TTS_LOG_BRIDGE_EMOTION_SCALE=4
TTS_LOG_BRIDGE_ENABLE_SUBTITLE=false
TTS_LOG_BRIDGE_ENABLE_TIMESTAMP=false
TTS_LOG_BRIDGE_DISABLE_MARKDOWN_FILTER=true
TTS_LOG_BRIDGE_SILENCE_DURATION_MS=0
TTS_LOG_BRIDGE_INTERRUPT=true
TTS_LOG_BRIDGE_EXPLICIT_LANGUAGE=zh
TTS_LOG_BRIDGE_START_FROM_END=true
TTS_LOG_BRIDGE_POLL_INTERVAL_SEC=0.2
TTS_LOG_BRIDGE_QUIET_PERIOD_SEC=1.5
TTS_LOG_BRIDGE_FLUSH_INTERVAL_SEC=0.35
TTS_LOG_BRIDGE_STREAM_MIN_CHARS=8
TTS_LOG_BRIDGE_MIN_TEXT_LENGTH=2
TTS_LOG_BRIDGE_REQUEST_TIMEOUT_SEC=15.0

# 音量控制配置
GO2_VOLUME_PREFER_VUI=true
GO2_VOLUME_AUTO_ENABLE_VUI_SWITCH=true
GO2_VUI_MIN_LEVEL=0
GO2_VUI_MAX_LEVEL=10
GO2_INIT_VOLUME_ON_START=false

# 兼容链路：Jetson 本地混音器配置
GO2_VOLUME_MIXER_DEVICE=default
GO2_VOLUME_MIXER_CONTROL=
GO2_AUDIO_COMMAND_TIMEOUT=1.0
