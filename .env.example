# =========================
# nuwax_robot_bridge 主配置文件
# 说明：
# 1. 这里是用户直接编辑的统一配置入口。
# 2. 格式统一为 KEY=VALUE。
# 3. 以 # 开头的是注释。
# 4. 同名环境变量优先级高于这里的值。
# 5. 当前文件已覆盖 settings.py 中全部实际读取的配置项。
# =========================

# -------------------------
# 日志配置
# 说明：
# 1. 新部署统一使用 NUWAX_LOG_*。
# 2. settings.py 仍兼容旧 GO2_PROXY_LOG_*，仅用于历史回退。
# -------------------------
NUWAX_LOG_DIR=/home/unitree/nuwax-robot-bridge
NUWAX_LOG_FILE=/home/unitree/nuwax-robot-bridge/nuwax_robot_bridge.log
NUWAX_LOG_LEVEL=INFO
NUWAX_LOG_MAX_LINES=100000
NUWAX_LOG_TRIM_CHECK_INTERVAL=200

# -------------------------
# 宿主机网关配置
# 说明：
# 1. 这是给容器内 nuwaclaw / relay 调用的正式入口。
# 2. token 请与容器内配置保持一致。
# 3. 这里把常见 Docker 网段放宽到 172.16.0.0/12，避免 bridge 网络切换后再次 403。
# -------------------------
NUWAX_GATEWAY_HOST=0.0.0.0
NUWAX_GATEWAY_PORT=8766
NUWAX_GATEWAY_PUBLIC_BASE_URL=http://host.docker.internal:8766
NUWAX_GATEWAY_ARTIFACT_DIR=/home/unitree/nuwax-robot-bridge/artifacts
NUWAX_GATEWAY_AGENT_TOKENS=agent-robot-bridge-token
NUWAX_GATEWAY_ADMIN_TOKENS=admin-robot-bridge-token
NUWAX_GATEWAY_AGENT_HIGH_RISK_ALLOWLIST=
NUWAX_GATEWAY_ALLOWED_SOURCE_CIDRS=127.0.0.1/32,172.16.0.0/12
NUWAX_GATEWAY_ALLOW_UNKNOWN_CLIENT_HOSTS=false
NUWAX_GATEWAY_SSE_KEEPALIVE_SEC=10.0
NUWAX_GATEWAY_WS_PING_INTERVAL_SEC=15.0

# -------------------------
# 容器内 relay 配置
# 说明：
# 1. 默认关闭，只有在容器内额外跑 relay 时才启用。
# 2. upstream token 一般直接复用 agent token。
# -------------------------
NUWAX_RELAY_ENABLED=false
NUWAX_RELAY_HOST=127.0.0.1
NUWAX_RELAY_PORT=9766
NUWAX_RELAY_UPSTREAM_BASE_URL=http://host.docker.internal:8766
NUWAX_RELAY_INCOMING_TOKENS=agent-robot-bridge-token
NUWAX_RELAY_UPSTREAM_TOKEN=agent-robot-bridge-token

# -------------------------
# 运行时数据与制品保留策略
# -------------------------
NUWAX_STATE_HISTORY_LIMIT=200
NUWAX_DIAGNOSTIC_HISTORY_LIMIT=200
NUWAX_OBSERVATION_HISTORY_LIMIT=100
NUWAX_PERCEPTION_HISTORY_LIMIT=100
NUWAX_LOCALIZATION_HISTORY_LIMIT=100
NUWAX_MAP_HISTORY_LIMIT=100
NUWAX_MAP_CATALOG_ROOT=/home/unitree/nuwax-robot-bridge/runtime_data/maps
NUWAX_MAP_AUTO_CREATE_LIBRARY=true
NUWAX_ACTIVE_MAP_RESTORE_ON_START=true
NUWAX_MAP_DELETE_ALSO_DELETE_LIBRARY=false
NUWAX_NAVIGATION_HISTORY_LIMIT=100
NUWAX_MEMORY_HISTORY_LIMIT=200
NUWAX_MEMORY_DB_PATH=/home/unitree/nuwax-robot-bridge/runtime_data/memory/vector_memory.db
NUWAX_MEMORY_TEXT_EMBEDDING_MODEL=tongyi-embedding-vision-flash-2026-03-06
NUWAX_MEMORY_TEXT_EMBEDDING_DIM=768
NUWAX_MEMORY_IMAGE_EMBEDDING_MODEL=tongyi-embedding-vision-flash-2026-03-06
NUWAX_MEMORY_IMAGE_EMBEDDING_DIM=768
NUWAX_MEMORY_EMBEDDING_API_KEY=
NUWAX_MEMORY_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1
NUWAX_MEMORY_EMBEDDING_TIMEOUT_SEC=20.0
NUWAX_MEMORY_VECTOR_STORE_BACKEND=sqlite_named_vectors
# 兼容说明：
# 1. settings.py 仍会兼容读取旧变量 NUWAX_MEMORY_EMBEDDING_MODEL / NUWAX_MEMORY_EMBEDDING_DIM。
# 2. 新部署不要再使用旧变量名，统一使用 TEXT / IMAGE 两组新配置。
# 当前默认：
# 1. 平台启动时默认不会自动启用记忆库，需由上层显式调用 enable_memory_library 后才会初始化向量模型
# 2. 默认文本/图像都走百炼在线多模态向量模型 tongyi-embedding-vision-flash-2026-03-06
# 3. 如需真正启用在线向量，请配置 NUWAX_MEMORY_EMBEDDING_API_KEY 或 DASHSCOPE_API_KEY
# 4. 如果缺少 API Key，运行时会自动回退到 hashing 文本向量并关闭图像向量链路，同时在日志中告警
# 5. 若要改回本地模型，可把 TEXT/IMAGE 模型名改成项目内目录，例如 runtime_data/models/BAAI__bge-m3 与 runtime_data/models/openai__clip-vit-base-patch32
# 6. 本地模型目录不会在启动阶段自动下载，如需启用请先运行 scripts/prepare_memory_models.py
NUWAX_ARTIFACT_RETENTION_DAYS=7
NUWAX_ARTIFACT_MAX_COUNT=1000
NUWAX_ARTIFACT_MAX_TOTAL_BYTES=1073741824
NUWAX_ARTIFACT_CLEANUP_BATCH_SIZE=200

# -------------------------
# 感知与视觉识别配置
# 说明：
# 1. 仓库不内置 YOLO26n 权重，请先按 `部署文档.md` 下载到 runtime_data/models/。
# 2. 本地检测默认优先使用 Ultralytics YOLO26n + TensorRT，引擎缺失时自动回退到 .pt。
# 3. 如需切换别的本地检测器，仍通过 DetectorBackend 扩展，不改上层工具面。
# 4. 云端语义识别统一走 OpenAI SDK 兼容接口，适合对接 OpenAI 及兼容服务。
# 5. 默认主线不是“每帧重检测”，而是“关键帧驱动 + 到点 burst 复核”。
# -------------------------
NUWAX_PERCEPTION_DEFAULT_DETECTOR_BACKEND=yolo_local
NUWAX_PERCEPTION_DEFAULT_SCENE_BACKEND=hybrid_scene

NUWAX_PERCEPTION_YOLO_ENABLED=true
NUWAX_PERCEPTION_YOLO_BACKEND_NAME=yolo_local
NUWAX_PERCEPTION_YOLO_MODEL=/home/unitree/nuwax-robot-bridge/runtime_data/models/yolo26n.pt
NUWAX_PERCEPTION_YOLO_RUNTIME=tensorrt
NUWAX_PERCEPTION_YOLO_ENGINE_PATH=/home/unitree/nuwax-robot-bridge/runtime_data/models/yolo26n.engine
NUWAX_PERCEPTION_YOLO_DEVICE=
NUWAX_PERCEPTION_YOLO_HALF=true
NUWAX_PERCEPTION_YOLO_INT8=false
NUWAX_PERCEPTION_YOLO_IMAGE_SIZE=640
NUWAX_PERCEPTION_YOLO_CONFIDENCE=0.25
NUWAX_PERCEPTION_YOLO_IOU=0.45
NUWAX_PERCEPTION_YOLO_MAX_DETECTIONS=100

NUWAX_PERCEPTION_OPENAI_ENABLED=false
NUWAX_PERCEPTION_OPENAI_BACKEND_NAME=openai_vision
NUWAX_PERCEPTION_OPENAI_BASE_URL=https://api.openai.com/v1
NUWAX_PERCEPTION_OPENAI_API_KEY=
NUWAX_PERCEPTION_OPENAI_MODEL=
NUWAX_PERCEPTION_OPENAI_API_STYLE=auto
NUWAX_PERCEPTION_OPENAI_TIMEOUT_SEC=20.0
NUWAX_PERCEPTION_OPENAI_MAX_TOKENS=1400
NUWAX_PERCEPTION_OPENAI_TEMPERATURE=0.0

# 持续视频感知运行时
NUWAX_PERCEPTION_STREAM_ENABLED=true
NUWAX_PERCEPTION_STREAM_AUTO_START=true
NUWAX_PERCEPTION_STREAM_CAMERA_ID=front_camera
NUWAX_PERCEPTION_STREAM_INTERVAL_SEC=0.5
NUWAX_PERCEPTION_STREAM_DETECTOR_BACKEND=
NUWAX_PERCEPTION_STREAM_STORE_ARTIFACT=false
NUWAX_PERCEPTION_STREAM_FAILURE_BACKOFF_SEC=2.0

# 关键帧策略
NUWAX_PERCEPTION_KEYFRAME_MIN_INTERVAL_SEC=1.0
NUWAX_PERCEPTION_KEYFRAME_MAX_INTERVAL_SEC=5.0
NUWAX_PERCEPTION_KEYFRAME_TRANSLATION_M=0.75
NUWAX_PERCEPTION_KEYFRAME_YAW_DEG=20.0
# 说明：
# 1. 当位姿、朝向和区域锚点几乎不变时，运行时会持续抑制关键帧，不会因为超过最大间隔就重复打云端 API
# 2. max interval 只在缺少位姿上下文时作为兜底
NUWAX_PERCEPTION_KEYFRAME_REMEMBER_ENABLED=true
NUWAX_PERCEPTION_KEYFRAME_REMEMBER_MIN_INTERVAL_SEC=15.0

# 到点 burst 复核
NUWAX_PERCEPTION_BURST_FRAME_COUNT=4
NUWAX_PERCEPTION_BURST_INTERVAL_SEC=0.08

# -------------------------
# DDS 与 SDK 配置
# -------------------------
GO2_DDS_IFACE=eth0
GO2_SDK_PATH=/home/unitree/unitree_sdk2_python
CYCLONEDDS_URI=<CycloneDDS><Domain><Compatibility><StandardsConformance>lax</StandardsConformance></Compatibility></Domain></CycloneDDS>

# 机器人地址别名
# 说明：
# 1. TTS 播放链路优先读取 TTS_PLAYER_ROBOT_IP。
# 2. 若未设置，会回退读取 GO2_ROBOT_IP，再回退读取 ROBOT_IP。
GO2_ROBOT_IP=
ROBOT_IP=

# -------------------------
# 低级控制默认参数
# -------------------------
GO2_LOW_LEVEL_KP=60.0
GO2_LOW_LEVEL_KD=5.0
GO2_LOW_LEVEL_MAX_VELOCITY=2.0
GO2_LOW_LEVEL_MAX_TORQUE=10.0
GO2_LOW_LEVEL_INTERVAL_SEC=0.002

# -------------------------
# 豆包双向流式鉴权配置
# -------------------------
DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
DOUBAO_RESOURCE_ID=seed-tts-1.0
DOUBAO_DEFAULT_SPEAKER=zh_female_sajiaonvyou_moon_bigtts
DOUBAO_DEFAULT_UID=nuwax_robot_bridge-tts
DOUBAO_DEFAULT_MODEL=
DOUBAO_DEFAULT_AUDIO_FORMAT=pcm
DOUBAO_DEFAULT_SAMPLE_RATE=24000
DOUBAO_REQUEST_USAGE_TOKENS=true
DOUBAO_SEND_APP_ID_HEADER=false
DOUBAO_SEND_APP_KEY_HEADER=true

# -------------------------
# TTS 播放器运行配置
# -------------------------
TTS_PLAYER_AUTO_START=true
TTS_PLAYER_PRINT_SUBTITLE=false
TTS_PLAYER_VOLUME=1.0

# 播放后端配置
# 可选：
# - robot_webrtc  : Go2 机身扬声器新链路
# - alsa_local    : Jetson 本地 ALSA/Pulse 兼容链路
TTS_PLAYER_BACKEND_MODE=robot_webrtc
TTS_PLAYER_FALLBACK_BACKEND_MODE=alsa_local

# Jetson 本地 ALSA/Pulse 兼容链路配置
TTS_PLAYER_PREFERRED_BACKEND=aplay
TTS_PLAYER_AUDIO_DEVICE=
TTS_PLAYER_ENABLE_SPK_CTL=true
TTS_PLAYER_ENABLE_APE_ROUTE=true
TTS_PLAYER_APE_CARD=APE
TTS_PLAYER_APE_ADMAIF=1
TTS_PLAYER_APE_SPEAKER=DSPK1

# Go2 机身扬声器新链路配置
TTS_PLAYER_ROBOT_IP=
TTS_PLAYER_ROBOT_MODE=ai
TTS_PLAYER_ROBOT_PYTHONPATH=
TTS_PLAYER_USE_MEGAPHONE=true
TTS_PLAYER_STREAMING_ENABLED=false
TTS_PLAYER_STREAMING_CHUNK_MS=200
TTS_PLAYER_ROBOT_CONNECT_TIMEOUT=15.0
TTS_PLAYER_ROBOT_REQUEST_TIMEOUT=20.0
TTS_PLAYER_UPLOAD_CHUNK_SIZE=61440
TTS_PLAYER_MEGAPHONE_CHUNK_SIZE=16384
TTS_PLAYER_SEGMENT_MIN_DURATION_SEC=3.0
TTS_PLAYER_AUTO_FALLBACK_TO_LOCAL=true

# -------------------------
# 日志监听转 TTS 配置
# 说明：
# 1. 直接监听 nuwaxbot 主日志里的 agent_message_chunk。
# 2. 在宿主机内直接调用本地 Doubao 双向流式客户端。
# 3. 如果日志文件位于 Docker volume，通常需要 root 或额外放宽权限。
# -------------------------
TTS_LOG_BRIDGE_ENABLED=false
TTS_LOG_BRIDGE_LOG_PATH=/var/lib/docker/volumes/nuwax_home/_data/.nuwaxbot/logs/main.log
TTS_LOG_BRIDGE_REQUIRE_ROOT=true
TTS_LOG_BRIDGE_SPEAKER=
TTS_LOG_BRIDGE_RESOURCE_ID=seed-tts-1.0
TTS_LOG_BRIDGE_UID=nuwax_robot_bridge-tts
TTS_LOG_BRIDGE_MODEL=
TTS_LOG_BRIDGE_AUDIO_FORMAT=pcm
TTS_LOG_BRIDGE_SAMPLE_RATE=24000
TTS_LOG_BRIDGE_SPEECH_RATE=0
TTS_LOG_BRIDGE_LOUDNESS_RATE=0
TTS_LOG_BRIDGE_EMOTION=
TTS_LOG_BRIDGE_EMOTION_SCALE=4
TTS_LOG_BRIDGE_ENABLE_SUBTITLE=false
TTS_LOG_BRIDGE_ENABLE_TIMESTAMP=false
TTS_LOG_BRIDGE_DISABLE_MARKDOWN_FILTER=true
TTS_LOG_BRIDGE_SILENCE_DURATION_MS=0
TTS_LOG_BRIDGE_INTERRUPT=true
TTS_LOG_BRIDGE_EXPLICIT_LANGUAGE=zh
TTS_LOG_BRIDGE_START_FROM_END=true
TTS_LOG_BRIDGE_POLL_INTERVAL_SEC=0.2
TTS_LOG_BRIDGE_QUIET_PERIOD_SEC=1.5
TTS_LOG_BRIDGE_FLUSH_INTERVAL_SEC=0.35
TTS_LOG_BRIDGE_STREAM_MIN_CHARS=8
TTS_LOG_BRIDGE_MIN_TEXT_LENGTH=2
TTS_LOG_BRIDGE_REQUEST_TIMEOUT_SEC=15.0
TTS_LOG_BRIDGE_START_RETRY_BACKOFF_SEC=2.0
TTS_LOG_BRIDGE_MAX_START_FAILURES_PER_TURN=3

# -------------------------
# 音量控制配置
# -------------------------
GO2_VOLUME_PREFER_VUI=true
GO2_VOLUME_AUTO_ENABLE_VUI_SWITCH=true
GO2_VUI_MIN_LEVEL=0
GO2_VUI_MAX_LEVEL=10
GO2_INIT_VOLUME_ON_START=false

# 兼容链路：Jetson 本地混音器配置
GO2_VOLUME_MIXER_DEVICE=default
GO2_VOLUME_MIXER_CONTROL=
GO2_AUDIO_COMMAND_TIMEOUT=1.0
