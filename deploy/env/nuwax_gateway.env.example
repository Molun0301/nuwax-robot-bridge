# `nuwax_robot_bridge` 宿主机网关环境变量示例

# 基础目录
NUWAX_GATEWAY_HOST=0.0.0.0
NUWAX_GATEWAY_PORT=8766
NUWAX_GATEWAY_PUBLIC_BASE_URL=http://host.docker.internal:8766
NUWAX_GATEWAY_ARTIFACT_DIR=/var/lib/nuwax_robot_bridge/artifacts

# 鉴权
NUWAX_GATEWAY_AGENT_TOKENS=dev-agent-token
NUWAX_GATEWAY_ADMIN_TOKENS=dev-admin-token
NUWAX_GATEWAY_AGENT_HIGH_RISK_ALLOWLIST=
NUWAX_GATEWAY_ALLOWED_SOURCE_CIDRS=127.0.0.1/32,172.17.0.0/16
NUWAX_GATEWAY_ALLOW_UNKNOWN_CLIENT_HOSTS=false

# 事件流
NUWAX_GATEWAY_SSE_KEEPALIVE_SEC=10
NUWAX_GATEWAY_WS_PING_INTERVAL_SEC=15

# relay
NUWAX_RELAY_ENABLED=false
NUWAX_RELAY_HOST=127.0.0.1
NUWAX_RELAY_PORT=9766
NUWAX_RELAY_UPSTREAM_BASE_URL=http://host.docker.internal:8766
NUWAX_RELAY_INCOMING_TOKENS=dev-relay-token
NUWAX_RELAY_UPSTREAM_TOKEN=dev-agent-token

# 日志与运行时目录
NUWAX_LOG_DIR=/var/log/nuwax_robot_bridge
NUWAX_LOG_FILE=/var/log/nuwax_robot_bridge/nuwax_robot_bridge.log
NUWAX_LOG_LEVEL=INFO

# Go2 / DDS
GO2_DDS_IFACE=eth0
GO2_SDK_PATH=/home/unitree/unitree_sdk2_python
