# =========================
# Go2 官方数据面配置示例
# 说明：
# 1. 这部分配置专属于 Go2 端侧能力。
# 2. 配置解析逻辑位于 drivers/robots/go2/settings.py。
# 3. 推荐实际部署时复制为 drivers/robots/go2/data_plane.env。
# 4. 环境变量优先级最高，其次是 drivers/robots/go2/data_plane.env，再其次是项目根目录 .env。
# =========================

# 是否启用 Go2 官方定位/地图/探索数据面
# 说明：
# 1. GO2_DATA_PLANE_REQUIRE_ROS2=true 只适用于纯 ROS2 模式。
# 2. 如果同时启用了 Unitree SDK2（例如官方 DDS 直连 / 官方后端），当前进程内不能再初始化 ROS2。
GO2_DATA_PLANE_ENABLED=false
GO2_DATA_PLANE_REQUIRE_ROS2=false
GO2_DATA_PLANE_SETUP_SCRIPT=/home/unitree/nuwax-robot-bridge/drivers/robots/go2/ros2_ws/install/setup.bash
GO2_CYCLONEDDS_LIB_DIR=
GO2_SDK_PATH=
GO2_DATA_PLANE_DDS_IFACE=eth0
GO2_NAMED_MAP_ARCHIVE_ROOT=/home/unitree/nuwax-robot-bridge/runtime_data/go2_named_maps
GO2_DATA_PLANE_STARTUP_WAIT_FOR_READY=true
GO2_DATA_PLANE_STARTUP_LOCALIZATION_TIMEOUT_SEC=6.0
GO2_DATA_PLANE_STARTUP_MAP_TIMEOUT_SEC=6.0
GO2_DATA_PLANE_STARTUP_POLL_INTERVAL_SEC=0.1

# -------------------------
# Go2 官方 DDS 直连
# 说明：
# 1. 位姿和激光雷达点云优先直接从宇树官方 DDS 读取。
# 2. 如果直连暂时不可用，才回退消费官方 ROS2 话题。
# -------------------------
GO2_DIRECT_DDS_ENABLED=true
GO2_DIRECT_DDS_POSE_TOPIC=rt/sportmodestate
GO2_DIRECT_DDS_POINT_CLOUD_TOPIC=rt/utlidar/cloud
GO2_DIRECT_DDS_READ_TIMEOUT_SEC=0.5
GO2_DIRECT_DDS_MAX_POINTS_PER_SCAN=1200

# -------------------------
# Go2 官方 ROS2 话题
# 说明：
# 1. 这些话题仅在“纯 ROS2 进程”模式下由当前进程直接订阅。
# 2. 若当前进程已启用 Unitree SDK2，则 ROS2 必须作为独立侧车进程运行，不能与网关主进程混用。
# 3. /map、grid_map、cost_map 若需接入平台，后续应通过独立进程桥接，不应与 SDK2 同进程初始化。
# -------------------------
GO2_DATA_PLANE_ODOM_TOPIC=/utlidar/robot_odom
GO2_DATA_PLANE_SECONDARY_ODOM_TOPICS=/uslam/localization/odom,/lio_sam_ros2/mapping/odometry,/odom_lio
GO2_DATA_PLANE_IMU_TOPIC=/utlidar/imu
GO2_DATA_PLANE_POINT_CLOUD_TOPIC=/utlidar/cloud
GO2_DATA_PLANE_TF_TOPIC=/tf
GO2_DATA_PLANE_TF_STATIC_TOPIC=/tf_static
GO2_DATA_PLANE_OCCUPANCY_TOPIC=/map
GO2_DATA_PLANE_GRID_MAP_TOPIC=/elevation_mapping_cupy/elevation_map_raw
GO2_DATA_PLANE_COST_MAP_TOPIC=/global_costmap/costmap

# -------------------------
# Go2 官方服务与运动控制
# 说明：
# 1. 建议保持按需启动；仅在明确发起探索或启用记忆库后，再通过 robot_state 启用建图相关服务。
# 2. 导航默认使用官方 sport 控制 + 官方里程计闭环，不再依赖本地 Nav2。
# -------------------------
GO2_OFFICIAL_BACKEND_ENABLED=true
GO2_OFFICIAL_SERVICES_AUTO_START=false
GO2_OFFICIAL_SERVICE_NAMES=unitree_lidar,unitree_lidar_slam,voxel_height_mapping,obstacles_avoid
GO2_OFFICIAL_CLIENT_TIMEOUT_SEC=3.0
GO2_OFFICIAL_GOAL_TOLERANCE_M=0.45
GO2_OFFICIAL_GOAL_YAW_TOLERANCE_RAD=0.45
GO2_OFFICIAL_CONTROL_LOOP_INTERVAL_SEC=0.1
GO2_OFFICIAL_MAX_LINEAR_VELOCITY_MPS=0.35
GO2_OFFICIAL_MAX_YAW_RATE_RPS=0.8
GO2_OFFICIAL_OBSTACLE_AVOIDANCE_DEFAULT_ENABLED=true

# -------------------------
# Go2 地图合成
# 说明：
# 1. Go2 端侧负责提供 /map / grid_map / cost_map / 点云等原始地图数据给平台侧公共导航栈。
# 2. traversability 通常来自官方 height mapping 或兼容 GridMap layer。
# 3. 如果拿不到官方 /map / grid_map / cost_map，Go2 数据面仍会基于官方点云补局部 / 全局栅格，作为平台侧输入。
# -------------------------
GO2_DATA_PLANE_MAP_FRAME=odom
GO2_DATA_PLANE_BASE_FRAME=body
GO2_DATA_PLANE_LIDAR_FRAME=utlidar_lidar
GO2_DATA_PLANE_TRAVERSABILITY_LAYER=traversability
GO2_DATA_PLANE_VALIDITY_LAYER=
GO2_DATA_PLANE_FREE_THRESHOLD=0.65
GO2_DATA_PLANE_LETHAL_THRESHOLD=0.20
GO2_DATA_PLANE_SEMANTIC_LAYERS=
GO2_DATA_PLANE_SEMANTIC_THRESHOLD=0.55
GO2_DATA_PLANE_SEMANTIC_MIN_CELLS=25
GO2_DATA_PLANE_GLOBAL_MAP_ENABLED=true
GO2_DATA_PLANE_GLOBAL_MAP_RESOLUTION_M=0.05
GO2_DATA_PLANE_GLOBAL_MAP_INFLATION_RADIUS_M=0.05
GO2_DATA_PLANE_LOCAL_MAP_ENABLED=true
GO2_DATA_PLANE_LOCAL_MAP_RESOLUTION_M=0.05
GO2_DATA_PLANE_LOCAL_MAP_WIDTH=200
GO2_DATA_PLANE_LOCAL_MAP_HEIGHT=200
GO2_DATA_PLANE_LOCAL_MAP_UPDATE_INTERVAL_SEC=0.5
GO2_DATA_PLANE_LOCAL_MAP_MAX_SCANS=12
GO2_DATA_PLANE_LOCAL_MAP_MAX_SCAN_AGE_SEC=20.0
GO2_DATA_PLANE_LOCAL_MAP_MIN_OBSTACLE_HEIGHT_M=-0.20
GO2_DATA_PLANE_LOCAL_MAP_MAX_OBSTACLE_HEIGHT_M=1.20
GO2_DATA_PLANE_LOCAL_MAP_MAX_RANGE_M=8.0
GO2_DATA_PLANE_LOCAL_MAP_INFLATION_RADIUS_M=0.05
GO2_DATA_PLANE_LIDAR_OFFSET_X_M=0.0
GO2_DATA_PLANE_LIDAR_OFFSET_Y_M=0.0
GO2_DATA_PLANE_LIDAR_OFFSET_Z_M=0.0
GO2_DATA_PLANE_LIDAR_YAW_OFFSET_RAD=0.0
GO2_NAVIGATION_PLANNER_INFLATION_RADIUS_M=0.05
GO2_COST_MAPPER_RESOLUTION_M=0.05
GO2_COST_MAPPER_OBSTACLE_INFLATION_RADIUS_M=0.05
GO2_VOXEL_MAPPER_VOXEL_SIZE=0.05

# -------------------------
# Go2 探索后端
# 说明：
# 1. 探索主逻辑已在平台公共层实现，Go2 端侧只负责提供定位 / 地图 / 运动执行能力。
# 2. 探索执行最终复用官方运动控制与官方里程计，不再依赖本地 Nav2。
# -------------------------
GO2_EXPLORATION_ENABLED=false
GO2_EXPLORATION_PREREQUISITE_WAIT_TIMEOUT_SEC=15.0
GO2_EXPLORATION_PREREQUISITE_POLL_INTERVAL_SEC=0.2
GO2_EXPLORATION_SAMPLE_RADIUS_M=1.5
GO2_EXPLORATION_SAMPLE_COUNT=8
GO2_EXPLORATION_MAX_GOAL_COST=75.0
GO2_EXPLORATION_GOAL_TIMEOUT_SEC=20.0
GO2_EXPLORATION_REACH_DISTANCE_M=0.45
GO2_EXPLORATION_STATUS_POLL_INTERVAL_SEC=0.2
