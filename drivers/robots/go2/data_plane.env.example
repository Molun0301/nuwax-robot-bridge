# =========================
# Go2 端侧数据面配置示例
# 说明：
# 1. 这部分配置专属于 Go2 端侧能力。
# 2. 配置解析逻辑位于 drivers/robots/go2/settings.py。
# 3. 推荐实际部署时复制为 drivers/robots/go2/data_plane.env。
# 4. 环境变量优先级最高，其次是 drivers/robots/go2/data_plane.env，再其次是项目根目录 .env。
# =========================

# 是否启用 Go2 端侧定位/地图/Nav2/探索数据面
GO2_DATA_PLANE_ENABLED=false
GO2_DATA_PLANE_REQUIRE_ROS2=false
GO2_DATA_PLANE_SETUP_SCRIPT=/home/unitree/nuwax_robot_bridge/drivers/robots/go2/ros2_ws/install/setup.bash
GO2_DATA_PLANE_DDS_IFACE=eth0

# -------------------------
# Go2 ROS2 数据面话题
# -------------------------
GO2_DATA_PLANE_ODOM_TOPIC=/odom_lio
GO2_DATA_PLANE_TF_TOPIC=/tf
GO2_DATA_PLANE_TF_STATIC_TOPIC=/tf_static
GO2_DATA_PLANE_OCCUPANCY_TOPIC=/map
GO2_DATA_PLANE_GRID_MAP_TOPIC=/elevation_mapping_cupy/elevation_map_raw
GO2_DATA_PLANE_COST_MAP_TOPIC=/global_costmap/costmap

# -------------------------
# Go2 地图合成
# 说明：
# 1. occupancy_grid / cost_map / semantic_map 都在 Go2 端侧运行时内合成。
# 2. traversability 通常来自 elevation_mapping_cupy 的 GridMap layer。
# -------------------------
GO2_DATA_PLANE_MAP_FRAME=odom
GO2_DATA_PLANE_BASE_FRAME=body
GO2_DATA_PLANE_TRAVERSABILITY_LAYER=traversability
GO2_DATA_PLANE_VALIDITY_LAYER=
GO2_DATA_PLANE_FREE_THRESHOLD=0.65
GO2_DATA_PLANE_LETHAL_THRESHOLD=0.20
GO2_DATA_PLANE_SEMANTIC_LAYERS=
GO2_DATA_PLANE_SEMANTIC_THRESHOLD=0.55
GO2_DATA_PLANE_SEMANTIC_MIN_CELLS=25

# -------------------------
# Go2 仓库内 ROS2 工作空间启动链
# -------------------------
GO2_LIDAR_PIPELINE_ENABLED=false
GO2_LIDAR_PIPELINE_AUTO_LAUNCH=false
GO2_LIDAR_PIPELINE_SETUP_SCRIPT=/home/unitree/nuwax_robot_bridge/drivers/robots/go2/ros2_ws/install/setup.bash
GO2_LIDAR_PIPELINE_LAUNCH_1=ros2 launch nuwax_go2_bringup go2_lidar_mapping.launch.py
GO2_LIDAR_PIPELINE_LAUNCH_2=
GO2_LIDAR_PIPELINE_LAUNCH_3=
GO2_LIDAR_PIPELINE_LAUNCH_STAGGER_SEC=2.0

# -------------------------
# Nav2 接入
# -------------------------
GO2_NAV2_ENABLED=false
GO2_NAV2_AUTO_LAUNCH=false
GO2_NAV2_SETUP_SCRIPT=/home/unitree/nuwax_robot_bridge/drivers/robots/go2/ros2_ws/install/setup.bash
GO2_NAV2_LAUNCH_COMMAND=ros2 launch nuwax_go2_bringup go2_nav2.launch.py
GO2_NAV2_NAVIGATE_TO_POSE_ACTION=/navigate_to_pose
GO2_NAV2_ACTION_WAIT_TIMEOUT_SEC=8.0
GO2_NAV2_LAUNCH_STABILIZE_SEC=5.0

# -------------------------
# Go2 探索后端
# 说明：
# 1. 当前探索后端在 Go2 目录内部实现。
# 2. 它复用 Nav2 导航能力，不依赖额外 frontier 包。
# -------------------------
GO2_EXPLORATION_ENABLED=false
GO2_EXPLORATION_SAMPLE_RADIUS_M=1.5
GO2_EXPLORATION_SAMPLE_COUNT=8
GO2_EXPLORATION_MAX_GOAL_COST=75.0
GO2_EXPLORATION_GOAL_TIMEOUT_SEC=20.0
GO2_EXPLORATION_REACH_DISTANCE_M=0.45
GO2_EXPLORATION_STATUS_POLL_INTERVAL_SEC=0.2
